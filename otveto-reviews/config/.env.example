# Токен авторизации Ответо = значение заголовка `authorization` из app.otveto.ru.
#
# Где взять:
#   1. Войдите на https://app.otveto.ru
#   2. DevTools (F12) → вкладка Network → откройте раздел «Анализ отзывов»
#   3. Найдите любой запрос на /graphql → Request Headers → скопируйте значение
#      заголовка `authorization`
#
# Токен привязан к аккаунту продавца и даёт доступ к его магазинам/отзывам.
# Храните как секрет; этот файл (config/.env) в .gitignore.
OTVETO_TOKEN=

# Эндпоинт (менять обычно не нужно).
OTVETO_GRAPHQL_URL=https://api.otveto.ru/graphql
